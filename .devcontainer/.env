# Common arguments valid for all on-demand tools.
function _common_args() {
    if [ -n "${GITHUB_ACTIONS}" ]; then
        common_vols="--volume /home/runner/work:/__w"
        common_misc="--workdir $(pwd) --rm"
    elif [ -n "${CODESPACES}" ]; then
        common_vols="--volume /workspaces:/workspaces"
        common_misc="--workdir $(pwd) --init --interactive --tty --rm"
    else
        common_vols="--volumes-from ${HOSTNAME}_devcontainer"
        common_misc="--workdir $(pwd) --init --interactive --tty --rm"
    fi

    common_x="--env=DISPLAY=:0 --volume=/tmp/.X11-unix/:/tmp/.X11-unix/"
    common_xauth=""
    if [ -n "${XAUTHORITY}" ]; then
        common_xauth="--volume=${XAUTHORITY}:/root/.Xauthority"
    fi

    common_args="$common_vols $common_x $common_xauth $common_misc"
    echo "$common_args"
}
export -f _common_args

############################################################
# QuestaSim
############################################################
export _questa_image="ghcr.io/nikleberg/questasim:25.1"
export _questa_args="--hostname questasim --mac-address=00:ab:ab:ab:ab:ab"

vsim() {
    docker run $(_common_args) $_questa_args $_questa_image "$@"
}
export -f vsim

vcom() {
    docker run $(_common_args) $_questa_args --entrypoint vcom $_questa_image "$@"
}
export -f vcom

questa_bash() {
    docker run $(_common_args) $_questa_args --entrypoint bash $_questa_image "$@"
}
export -f questa_bash

############################################################
# Quartus
############################################################
export _quartus_image="ghcr.io/nikleberg/quartus:25.1-cycloneiv"
export _quartus_args="--hostname quartus --volume=/dev:/dev --privileged"

quartus_sh() {
    docker run $(_common_args) $_quartus_args --entrypoint quartus_sh $_quartus_image "$@"
}
export -f quartus_sh

quartus() {
    docker run $(_common_args) $_quartus_args --entrypoint quartus $_quartus_image "$@"
}
export -f quartus

quartus_bash() {
    docker run $(_common_args) $_quartus_args --entrypoint bash $_quartus_image "$@"
}
export -f quartus_bash

############################################################
# GHDL + OSS tools
############################################################
ghdl() {
    local ghdl_args="--hostname ghdl --entrypoint ghdl $(_common_args)"
    docker run $ghdl_args ghcr.io/hdl/formal "$@"
}
export -f ghdl

sby() {
    local ghdl_args="--hostname ghdl --entrypoint sby $(_common_args)"
    docker run $ghdl_args ghcr.io/hdl/formal "$@"
}
export -f sby

yosys() {
    local ghdl_args="--hostname ghdl --entrypoint yosys $(_common_args)"
    docker run $ghdl_args ghcr.io/hdl/formal "$@"
}
export -f yosys

gtkwave() {
    local ghdl_args="--hostname ghdl --entrypoint gtkwave $(_common_args)"
    docker run $ghdl_args ghcr.io/hdl/gtkwave "$@"
}
export -f gtkwave

ghdl_bash() {
    local ghdl_args="--hostname ghdl --entrypoint bash $(_common_args)"
    docker run $ghdl_args ghcr.io/hdl/formal "$@"
}
export -f ghdl_bash

############################################################
# NVC
############################################################
export _nvc_image="ghcr.io/nikleberg/nvc:master"
export _nvc_args="--hostname nvc"

nvc() {
    docker run $(_common_args) $_nvc_args --entrypoint nvc $_nvc_image "$@"
}
export -f nvc

nvc_bash() {
    docker run $(_common_args) $_nvc_args --entrypoint bash $_nvc_image "$@"
}
export -f nvc_bash
