#**************************************************************
# Time Information
#**************************************************************
set_time_format -unit ns -decimal_places 3

#**************************************************************
# Create Clock
#**************************************************************
# 200 MHz
create_clock -name {clk} -period 5.000 -waveform { 0.000 2.500 } [get_ports {clk}]

#**************************************************************
# Set Clock Uncertainty
#**************************************************************
derive_clock_uncertainty -add
